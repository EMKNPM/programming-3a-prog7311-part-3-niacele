@model Global_Logistics_Management_System___ST10439898.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Staff Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechMove - Staff Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="background-color: #2C3E50;">

    <style>
            :root {
                --dark-grey: #2C3E50;
                --burnt-orange: #E67E22;
                --green: #27AE60;
                --white: #FFFFFF;
                --light-grey: #34495E;
            }

            .login-container {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, var(--dark-grey) 0%, var(--light-grey) 100%);
                position: relative;
                overflow: hidden;
            }

                /* Decorative circles background */
                .login-container::before {
                    content: '';
                    position: absolute;
                    width: 300px;
                    height: 300px;
                    background: var(--burnt-orange);
                    border-radius: 50%;
                    opacity: 0.1;
                    top: -100px;
                    left: -100px;
                }

                .login-container::after {
                    content: '';
                    position: absolute;
                    width: 400px;
                    height: 400px;
                    background: var(--green);
                    border-radius: 50%;
                    opacity: 0.1;
                    bottom: -150px;
                    right: -150px;
                }

            .login-card {
                background: white;
                border-radius: 20px;
                padding: 0;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
                max-width: 450px;
                width: 100%;
                margin: 20px;
                overflow: hidden;
                position: relative;
                z-index: 10;
            }

            .login-header {
                background-color: var(--dark-grey);
                color: white;
                padding: 30px;
                text-align: center;
            }

                .login-header h1 {
                    font-size: 2rem;
                    margin: 0;
                    font-weight: bold;
                }

                .login-header p {
                    font-size: 0.9rem;
                    margin: 10px 0 0 0;
                    opacity: 0.8;
                }

            .login-icon {
                font-size: 3rem;
                margin-bottom: 10px;
            }

            .login-body {
                padding: 30px;
            }

            .form-group {
                margin-bottom: 25px;
            }

            .control-label {
                font-weight: 600;
                color: var(--dark-grey);
                margin-bottom: 8px;
                display: block;
            }

            .input-group-text {
                background-color: var(--dark-grey);
                color: white;
                border: none;
            }

            .form-control {
                border: 1px solid #ddd;
                border-radius: 8px;
                padding: 12px 15px;
                font-size: 1rem;
                transition: all 0.3s ease;
            }

                .form-control:focus {
                    border-color: var(--burnt-orange);
                    box-shadow: 0 0 0 3px rgba(230, 126, 34, 0.1);
                    outline: none;
                }

            .btn-login {
                background-color: var(--burnt-orange);
                color: white;
                border: none;
                padding: 12px;
                border-radius: 8px;
                font-size: 1rem;
                font-weight: 600;
                width: 100%;
                cursor: pointer;
                transition: background-color 0.3s ease;
            }

                .btn-login:hover {
                    background-color: #D35400;
                }

            .text-danger {
                font-size: 0.85rem;
                margin-top: 5px;
                display: block;
                color: #e74c3c;
            }

            .text-muted {
                font-size: 0.8rem;
                color: #7f8c8d;
            }

            .demo-credentials {
                background-color: #f8f9fa;
                border-radius: 8px;
                padding: 15px;
                margin-top: 20px;
                text-align: center;
                border-left: 4px solid var(--burnt-orange);
            }

                .demo-credentials p {
                    margin: 5px 0;
                    font-size: 0.85rem;
                }

                .demo-credentials strong {
                    color: var(--dark-grey);
                }

            .back-link {
                text-align: center;
                margin-top: 20px;
            }

                .back-link a {
                    color: var(--burnt-orange);
                    text-decoration: none;
                    font-size: 0.9rem;
                }

                    .back-link a:hover {
                        text-decoration: underline;
                    }

            hr {
                display: none;
            }
    </style>

    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="login-icon">🚚</div>
                <h1>TechMove</h1>
                <p>Staff Login Portal</p>
            </div>

            <div class="login-body">
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Username" class="control-label">Staff Username</label>
                        <div class="input-group">
                            <span class="input-group-text"></span>
                            <input asp-for="Username" class="form-control" placeholder="Enter your username" />
                        </div>
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="control-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"></span>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn-login">Login to Dashboard</button>
                    </div>
                </form>

                <div class="demo-credentials">
                    <p><strong> Demo Credentials</strong></p>
                    <p>Username: <strong>admin@techmove.com</strong></p>
                    <p>Password: <strong>Admin123!</strong></p>
                    <p class="text-muted" style="margin-top: 8px;">* For testing purposes only</p>
                </div>

                <div class="back-link">
                    <a asp-controller="Home" asp-action="Index">← Back to Home</a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>